datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  rol      String // ADMIN, VENDEDOR, CONFITERIA
}

model Funcion {
  id          Int       @id @default(autoincrement())
  pelicula    String
  sala        String
  horario     DateTime
  duracionMin Int
  precioBase  Float
  asientos    Asiento[]
}

model Asiento {
  id          Int       @id @default(autoincrement())
  codigo      String    // Ej: "A1", "B2"
  estado      String    @default("disponible") // disponible, bloqueado, vendido
  bloqueadoEn DateTime? 
  funcionId   Int
  funcion     Funcion   @relation(fields: [funcionId], references: [id])
}